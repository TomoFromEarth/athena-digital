# Resend — create a key at https://resend.com/api-keys (never commit real keys)
RESEND_API_KEY=

# Verified sender. Sandbox/testing often uses: Your Name <onboarding@resend.dev>
# Production: use an address on a domain verified in the Resend dashboard.
EMAIL_FROM=

# Where contact notifications are delivered (optional; code defaults to julia@athenadigital.me).
# Until a domain is verified in Resend, test accounts may only send TO the Resend login email;
# set this to that address for testing, or verify athenadigital.me at https://resend.com/domains
CONTACT_INQUIRY_TO_EMAIL=
